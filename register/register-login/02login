#!/usr/bin/env bash
# =============================================================================
# 02login - 批量将已注册的 OpenAI 账号登录到 Codexbar
#
# 用法:
#   ./02login [数量]
#   COUNT=50 ./02login
#   INTERVAL_SECS=150 ./02login 20
#   EMAIL_FILTER="xxx@icloud.com" ./02login 1   # 只登录指定邮箱
#
# 环境变量:
#   COUNT          - 本次登录数量，默认读取 CSV 中所有满足自动导入 gate 的账号
#   INTERVAL_SECS  - 每次登录间隔秒数，默认 150
#   CSV_PATH       - codex.csv 路径，默认 ../codex.csv
#   EMAIL_FILTER   - 只处理指定邮箱（可选）
# =============================================================================

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

IMPORT_SCRIPT="$ROOT_DIR/scripts/import_openai_account_to_codexbar.sh"
CSV_SHADOW_HELPER="$ROOT_DIR/scripts/codex_csv_shadow.sh"
CSV_STATE_HELPER="$ROOT_DIR/scripts/codex_csv_state.py"

COUNT="${COUNT:-}"
INTERVAL_SECS="${INTERVAL_SECS:-150}"
CSV_PATH="${CSV_PATH:-$ROOT_DIR/codex.csv}"
EMAIL_FILTER="${EMAIL_FILTER:-}"

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '❌ 缺少命令: %s\n' "$1" >&2
    exit 127
  }
}

csv_upsert_row() {
  local email="$1" password="$2" status="$3" url="$4" auth_method="$5" phase="$6" failure_category="$7" manual_action="$8"
  shift 8
  python3 "$CSV_STATE_HELPER" upsert "$CSV_PATH" \
    --email "$email" \
    --password "$password" \
    --status "$status" \
    --url "$url" \
    --auth-method "$auth_method" \
    --phase "$phase" \
    --failure-category "$failure_category" \
    --manual-action "$manual_action" \
    "$@"
}

require_cmd python3
source "$CSV_SHADOW_HELPER"
codex_csv_begin_mutation "$CSV_PATH"
python3 "$CSV_STATE_HELPER" ensure "$CSV_PATH"

# 获取满足自动导入 gate 的账号列表
IMPORT_CANDIDATE_LIST="$(python3 "$CSV_STATE_HELPER" list-import-candidates "$CSV_PATH" --email-filter "$EMAIL_FILTER")"
if [[ -z "$IMPORT_CANDIDATE_LIST" ]]; then
  if [[ -n "$EMAIL_FILTER" ]]; then
    printf 'ℹ️  CSV 中没有满足自动导入条件的账号匹配 %s\n' "$EMAIL_FILTER"
  else
    printf 'ℹ️  CSV 中没有满足自动导入条件的账号（可能已全部导入，或需要人工接管）\n'
  fi
  printf 'BATCH_IMPORTED_COUNT=0\n'
  printf 'BATCH_FAILED_COUNT=0\n'
  exit 0
fi

# 解析为数组
mapfile -t ALL_IMPORT_CANDIDATES < <(printf '%s\n' "$IMPORT_CANDIDATE_LIST")
TOTAL_AVAILABLE=$(( ${#ALL_IMPORT_CANDIDATES[@]} / 2 ))

# 确定本次要登录的数量
if [[ -z "$COUNT" ]]; then
  LOGIN_COUNT=$TOTAL_AVAILABLE
else
  LOGIN_COUNT="$COUNT"
  if (( LOGIN_COUNT > TOTAL_AVAILABLE )); then
    LOGIN_COUNT=$TOTAL_AVAILABLE
  fi
fi

printf '========================================\n'
printf '🔐 开始批量登录 Codexbar\n'
printf '📋 本次登录: %s / 可用: %s\n' "$LOGIN_COUNT" "$TOTAL_AVAILABLE"
printf '⏱  登录间隔: %s 秒\n' "$INTERVAL_SECS"
printf '📁 CSV 路径: %s\n' "$CSV_PATH"
printf '========================================\n'

IMPORTED=0
FAILED=0

for i in $(seq 0 $((LOGIN_COUNT - 1))); do
  idx=$(( i * 2 ))
  email="${ALL_IMPORT_CANDIDATES[$idx]}"
  password="${ALL_IMPORT_CANDIDATES[$idx + 1]}"
  item=$(( i + 1 ))

  printf '\n[%s/%s] 登录: %s\n' "$item" "$LOGIN_COUNT" "$email"

  if output="$(CODEX_CSV_PATH="$CSV_PATH" CODEX_CSV_EMAIL="$email" OPENAI_EMAIL="$email" OPENAI_PASSWORD="$password" "$IMPORT_SCRIPT" 2>&1)"; then
    printf '%s\n' "$output"
    AUTH_METHOD="$(printf '%s\n' "$output" | sed -n 's/^AUTH_METHOD=//p' | tail -n 1)"
    LAST_SEEN_URL_HOST_PATH="$(printf '%s\n' "$output" | sed -n 's/^LAST_SEEN_URL_HOST_PATH=//p' | tail -n 1)"
    codex_csv_begin_mutation "$CSV_PATH"
    csv_upsert_row "$email" "$password" "completed" "${LAST_SEEN_URL_HOST_PATH:-}" "${AUTH_METHOD:-password}" "import" "" "none" --retry-count 0
    codex_csv_sync_shadow "$CSV_PATH"
    printf '✅ [%s/%s] 导入成功\n' "$item" "$LOGIN_COUNT"
    ((IMPORTED++))
  else
    EXIT_CODE=$?
    FAILURE_CATEGORY="$(printf '%s\n' "$output" | sed -n 's/^IMPORT_FAILURE_CATEGORY=//p' | tail -n 1)"
    WORKFLOW_STATUS="$(printf '%s\n' "$output" | sed -n 's/^WORKFLOW_STATUS=//p' | tail -n 1)"
    MANUAL_ACTION="$(printf '%s\n' "$output" | sed -n 's/^MANUAL_ACTION=//p' | tail -n 1)"
    LAST_SEEN_URL_HOST_PATH="$(printf '%s\n' "$output" | sed -n 's/^LAST_SEEN_URL_HOST_PATH=//p' | tail -n 1)"
    AUTH_METHOD="$(printf '%s\n' "$output" | sed -n 's/^AUTH_METHOD=//p' | tail -n 1)"
    printf '%s\n' "$output" >&2
    codex_csv_begin_mutation "$CSV_PATH"
    if [[ "$WORKFLOW_STATUS" == "retryable_failure" ]]; then
      csv_upsert_row "$email" "$password" "$WORKFLOW_STATUS" "${LAST_SEEN_URL_HOST_PATH:-}" "${AUTH_METHOD:-password}" "import" "${FAILURE_CATEGORY:-provider_timeout}" "${MANUAL_ACTION:-retry_after_local_fix}" --increment-retry-count
    else
      csv_upsert_row "$email" "$password" "${WORKFLOW_STATUS:-manual_required}" "${LAST_SEEN_URL_HOST_PATH:-}" "${AUTH_METHOD:-password}" "import" "${FAILURE_CATEGORY:-provider_timeout}" "${MANUAL_ACTION:-complete_provider_challenge}"
    fi
    codex_csv_sync_shadow "$CSV_PATH"
    if [[ -n "$FAILURE_CATEGORY" ]]; then
      printf '⚠️  失败分类: %s\n' "$FAILURE_CATEGORY" >&2
    fi
    printf '❌ [%s/%s] 导入失败 (exit %d)\n' "$item" "$LOGIN_COUNT" "$EXIT_CODE" >&2
    ((FAILED++))
  fi

  # 间隔
  if (( i < LOGIN_COUNT - 1 )); then
    printf '⏳ 等待 %s 秒...\n' "$INTERVAL_SECS"
    sleep "$INTERVAL_SECS"
  fi
done

printf '\n========================================\n'
printf '📊 登录完成\n'
printf '✅ 成功: %s\n' "$IMPORTED"
printf '❌ 失败: %s\n' "$FAILED"
printf '📁 结果已写入: %s\n' "$CSV_PATH"
printf '========================================\n'

if (( FAILED > 0 )); then
  exit 1
fi
