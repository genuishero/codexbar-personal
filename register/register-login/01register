#!/usr/bin/env bash
# =============================================================================
# 01register - 批量注册 OpenAI 账号（不登录 Codexbar）
#
# 用法:
#   ./01register [数量]
#   COUNT=50 ./01register
#   INTERVAL_SECS=180 ./01register 20
#
# 环境变量:
#   COUNT          - 注册账号数量，默认 10
#   INTERVAL_SECS  - 每次注册间隔秒数，默认 10
#   CSV_PATH       - codex.csv 路径，默认 ../codex.csv
# =============================================================================

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

HIDE_MY_EMAIL_SCRIPT="$ROOT_DIR/chatgpt-anon-register/scripts/create_hide_my_email.sh"
REGISTER_SCRIPT="$ROOT_DIR/chatgpt-anon-register/scripts/register_chatgpt.sh"
CSV_SHADOW_HELPER="$ROOT_DIR/scripts/codex_csv_shadow.sh"
CSV_STATE_HELPER="$ROOT_DIR/scripts/codex_csv_state.py"

COUNT="${COUNT:-${1:-10}}"
INTERVAL_SECS="${INTERVAL_SECS:-10}"
CSV_PATH="${CSV_PATH:-$ROOT_DIR/codex.csv}"

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '❌ 缺少命令: %s\n' "$1" >&2
    exit 127
  }
}

csv_upsert_row() {
  local email="$1" password="$2" status="$3" url="$4" auth_method="$5" phase="$6" failure_category="$7" manual_action="$8"
  shift 8
  python3 "$CSV_STATE_HELPER" upsert "$CSV_PATH" \
    --email "$email" \
    --password "$password" \
    --status "$status" \
    --url "$url" \
    --auth-method "$auth_method" \
    --phase "$phase" \
    --failure-category "$failure_category" \
    --manual-action "$manual_action" \
    "$@"
}

require_cmd bash
require_cmd python3
require_cmd swift
require_cmd playwright-cli
source "$CSV_SHADOW_HELPER"
codex_csv_begin_mutation "$CSV_PATH"
python3 "$CSV_STATE_HELPER" ensure "$CSV_PATH"

printf '========================================\n'
printf '🚀 开始批量注册 OpenAI 账号\n'
printf '📋 目标数量: %s\n' "$COUNT"
printf '⏱  注册间隔: %s 秒\n' "$INTERVAL_SECS"
printf '📁 CSV 路径: %s\n' "$CSV_PATH"
printf '========================================\n'

SUCCESS=0
FAILED=0

for i in $(seq 1 "$COUNT"); do
  printf '\n[%s/%s] 开始注册...\n' "$i" "$COUNT"

  # 1. 生成 Hide My Email 别名
  RELAY_EMAIL="$("$HIDE_MY_EMAIL_SCRIPT" 2>/dev/null)" || true
  if [[ -z "$RELAY_EMAIL" ]]; then
    printf '❌ [%s/%s] 创建 iCloud 邮箱失败\n' "$i" "$COUNT" >&2
    csv_upsert_row "" "" "retryable_failure" "" "unknown" "register" "hide_my_email_failed" "retry_after_local_fix"
    ((FAILED++))
    continue
  fi
  printf '📧 生成邮箱: %s\n' "$RELAY_EMAIL"

  # 2. 注册 ChatGPT/OpenAI
  REGISTER_OUTPUT="$(RELAY_EMAIL="$RELAY_EMAIL" "$REGISTER_SCRIPT" 2>&1)" && EXIT_CODE=0 || EXIT_CODE=$?

  REG_EMAIL="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^REGISTERED_EMAIL=//p' | tail -n 1)"
  REG_PASSWORD="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^PASSWORD=//p' | tail -n 1)"
  REG_STATUS="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^REGISTRATION_STATUS=//p' | tail -n 1)"
  REG_METHOD="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^AUTH_METHOD=//p' | tail -n 1)"
  WORKFLOW_PHASE="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^WORKFLOW_PHASE=//p' | tail -n 1)"
  WORKFLOW_STATUS="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^WORKFLOW_STATUS=//p' | tail -n 1)"
  FAILURE_CATEGORY="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^FAILURE_CATEGORY=//p' | tail -n 1)"
  MANUAL_ACTION="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^MANUAL_ACTION=//p' | tail -n 1)"
  IMPORT_ELIGIBLE="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^IMPORT_ELIGIBLE=//p' | tail -n 1)"
  LAST_SEEN_URL_HOST_PATH="$(printf '%s\n' "$REGISTER_OUTPUT" | sed -n 's/^LAST_SEEN_URL_HOST_PATH=//p' | tail -n 1)"

  TARGET_EMAIL="${REG_EMAIL:-$RELAY_EMAIL}"
  TARGET_PHASE="${WORKFLOW_PHASE:-register}"
  TARGET_STATUS="${WORKFLOW_STATUS:-retryable_failure}"
  TARGET_METHOD="${REG_METHOD:-unknown}"
  TARGET_FAILURE="${FAILURE_CATEGORY:-}"
  TARGET_MANUAL="${MANUAL_ACTION:-none}"
  TARGET_URL="${LAST_SEEN_URL_HOST_PATH:-}"

  if [[ "$TARGET_STATUS" == "completed" ]]; then
    csv_upsert_row "$TARGET_EMAIL" "$REG_PASSWORD" "$TARGET_STATUS" "$TARGET_URL" "$TARGET_METHOD" "$TARGET_PHASE" "" "$TARGET_MANUAL" --retry-count 0
    printf '✅ [%s/%s] 注册完成 | %s | 方式: %s' "$i" "$COUNT" "$TARGET_EMAIL" "${REG_METHOD:-unknown}"
    if [[ "$IMPORT_ELIGIBLE" == "1" ]]; then
      printf ' | 可自动导入\n'
    else
      printf ' | 需人工接管: %s\n' "$TARGET_MANUAL"
    fi
    ((SUCCESS++))
  else
    csv_upsert_row "$TARGET_EMAIL" "$REG_PASSWORD" "$TARGET_STATUS" "$TARGET_URL" "$TARGET_METHOD" "$TARGET_PHASE" "$TARGET_FAILURE" "$TARGET_MANUAL" --increment-retry-count
    printf '❌ [%s/%s] 注册未完成 | 状态: %s' "$i" "$COUNT" "${TARGET_STATUS:-unknown}" >&2
    if [[ -n "$TARGET_FAILURE" ]]; then
      printf ' | 分类: %s' "$TARGET_FAILURE" >&2
    fi
    if [[ -n "$TARGET_MANUAL" && "$TARGET_MANUAL" != "none" ]]; then
      printf ' | 动作: %s' "$TARGET_MANUAL" >&2
    fi
    printf '\n' >&2
    ((FAILED++))
  fi

  # 间隔
  if (( i < COUNT )); then
    printf '⏳ 等待 %s 秒...\n' "$INTERVAL_SECS"
    sleep "$INTERVAL_SECS"
  fi
done

codex_csv_sync_shadow "$CSV_PATH"

printf '\n========================================\n'
printf '📊 注册完成\n'
printf '✅ 成功: %s\n' "$SUCCESS"
printf '❌ 失败: %s\n' "$FAILED"
printf '📁 结果已写入: %s\n' "$CSV_PATH"
printf '========================================\n'
printf '\n下一步: 运行 ./02login 将已注册的账号登录到 Codexbar\n'

if (( FAILED > 0 )); then
  exit 1
fi
